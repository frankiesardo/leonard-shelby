---
layout: base.njk
title: Flashcards
permalink: /flashcards/
---
<h1>Flashcards</h1>
<p>{{ collections.flashcards | length }} cards.</p>

<div class="random-buttons">
  <button onclick="goRandom(flashcardUrls)">Random flashcard</button>
</div>
<script>
var flashcardUrls = [{% for card in collections.flashcards %}"{{ card.url | url }}"{% if not loop.last %},{% endif %}{% endfor %}];
function goRandom(list) { if (list.length) window.location.href = list[Math.floor(Math.random() * list.length)]; }
</script>

<ul class="flashcard-list">
  {% for card in collections.flashcards | sort(attribute="fileSlug") %}
  <li>
    <a href="{{ card.url }}">{{ card.fileSlug }}</a>
    {% if card.data.idea %}<span class="flashcard-idea-tag">{{ card.data.idea }}</span>{% endif %}
  </li>
  {% endfor %}
</ul>
